{
  "version": "2.0.0",
  "tasks": [
    {
      // The preLaunchTask for F5. Depends on the viewer build first
      // (extension's build copies the viewer's dist into its own bundle),
      // then runs its own command to bundle the extension.
      "label": "zettelgeist: build extension",
      "type": "shell",
      "command": "node",
      "args": [
        "${workspaceFolder}/packages/vscode-extension/scripts/build.mjs"
      ],
      // Invoke the build scripts directly with `node` — sidesteps the
      // "pnpm isn't on VSCode's task-shell PATH" problem entirely. Node
      // itself must be on PATH for the extension host to launch at all,
      // so it's always reachable here. Assumes deps are already installed
      // (one-time: `pnpm install` from a terminal).
      "dependsOrder": "sequence",
      "dependsOn": ["zettelgeist: build viewer"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "zettelgeist: build viewer",
      "type": "shell",
      "command": "node",
      "args": [
        "${workspaceFolder}/packages/viewer/scripts/build.mjs"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    }
  ]
}
