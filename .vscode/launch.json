{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Zettelgeist: Extension Development Host",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/vscode-extension",
        "${workspaceFolder}/examples/demo"
      ],
      "outFiles": [
        "${workspaceFolder}/packages/vscode-extension/dist/**/*.js"
      ],
      "preLaunchTask": "zettelgeist: build extension"
    }
  ]
}
