node_modules/
dist/
*.tsbuildinfo
# Defensive: stop tsc emit-in-place leaks if someone runs `tsc` from a package
# root without `outDir`. Source files are .ts only — anything next to them in
# .js / .d.ts / .js.map is build output that doesn't belong in git.
packages/*/src/**/*.js
packages/*/src/**/*.d.ts
packages/*/src/**/*.js.map
.DS_Store
# Per-spec claim files. v0.1 single `.claim`, v0.2 per-actor `.claim-<slug>`.
# Both shapes are ephemeral tool state, NOT part of the spec format.
.claim
.claim-*
# Whitelist: examples, demo, and conformance fixtures intentionally check
# claim files in so the demo / fixtures reproduce on a fresh clone.
!examples/**/.claim
!examples/**/.claim-*
!spec/conformance/fixtures/**/.claim
!spec/conformance/fixtures/**/.claim-*
.zettelgeist/regen-cache.json
.zettelgeist/exports/
**/.zettelgeist/regen-cache.json
**/.zettelgeist/exports/
test-results/
playwright-report/

# VS Code / Open VSX extension packaging artifacts
*.vsix

# Claude Code per-session state (scheduled-task locks, project memory).
# Not project state — ignore so it doesn't surface in `git status`.
.claude/
