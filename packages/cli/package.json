{
  "name": "@zettelgeist/cli",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "author": "Mo <motechnix@gmail.com>",
  "description": "Zettelgeist CLI: regen, validate, install-hook, serve, export-doc commands.",
  "keywords": ["zettelgeist", "spec-driven-development", "markdown", "project-management", "cli"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/morrieinmaas/zettelgeist.git",
    "directory": "packages/cli"
  },
  "bugs": "https://github.com/morrieinmaas/zettelgeist/issues",
  "homepage": "https://github.com/morrieinmaas/zettelgeist#readme",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": { "zettelgeist": "./dist/bin.js" },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "node scripts/bundle.mjs && chmod +x dist/bin.js && cp -r templates dist/templates && node scripts/copy-viewer.mjs",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "js-yaml": "^3.14.2",
    "marked": "^14.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@types/js-yaml": "^4.0.9",
    "@zettelgeist/core": "workspace:*",
    "@zettelgeist/fs-adapters": "workspace:*",
    "@zettelgeist/git-hook": "workspace:*",
    "esbuild": "^0.24.0"
  }
}
