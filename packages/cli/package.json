{
  "name": "@zettelgeist/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": { "zettelgeist": "./dist/bin.js" },
  "files": ["dist"],
  "scripts": {
    "build": "node scripts/bundle.mjs && chmod +x dist/bin.js && cp -r templates dist/templates && node scripts/copy-viewer.mjs",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@zettelgeist/core": "workspace:*",
    "@zettelgeist/fs-adapters": "workspace:*",
    "gray-matter": "^4.0.3",
    "js-yaml": "^3.14.2",
    "marked": "^14.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "esbuild": "^0.24.0"
  }
}
