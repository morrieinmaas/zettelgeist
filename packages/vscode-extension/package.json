{
  "name": "zettelgeist",
  "displayName": "Zettelgeist",
  "description": "Spec-driven project management for VS Code. Opens the Zettelgeist viewer in a panel; every action is a markdown edit + commit.",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "publisher": "morriearty-zg",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/morrieinmaas/zettelgeist.git",
    "directory": "packages/vscode-extension"
  },
  "bugs": {
    "url": "https://github.com/morrieinmaas/zettelgeist/issues"
  },
  "homepage": "https://github.com/morrieinmaas/zettelgeist#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization",
    "Notebooks"
  ],
  "keywords": [
    "zettelgeist",
    "specs",
    "spec-driven",
    "kanban",
    "agent",
    "mcp",
    "markdown",
    "project management"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "workspaceContains:**/.zettelgeist.yaml"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "zettelgeist",
          "title": "Zettelgeist",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "zettelgeist": [
        {
          "id": "zettelgeistSpecs",
          "name": "Specs",
          "icon": "media/icon.svg",
          "contextualTitle": "Zettelgeist"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "zettelgeist.open",
          "when": "view == zettelgeistSpecs",
          "group": "navigation@1"
        },
        {
          "command": "zettelgeist.refreshTree",
          "when": "view == zettelgeistSpecs",
          "group": "navigation@2"
        }
      ]
    },
    "commands": [
      {
        "command": "zettelgeist.open",
        "title": "Open Board",
        "category": "Zettelgeist",
        "icon": "$(open-preview)"
      },
      {
        "command": "zettelgeist.regen",
        "title": "Regenerate INDEX.md",
        "category": "Zettelgeist"
      },
      {
        "command": "zettelgeist.installHook",
        "title": "Install Pre-commit Hook",
        "category": "Zettelgeist"
      },
      {
        "command": "zettelgeist.refreshTree",
        "title": "Refresh",
        "category": "Zettelgeist",
        "icon": "$(refresh)"
      },
      {
        "command": "zettelgeist.openInBrowser",
        "title": "Open in Browser",
        "category": "Zettelgeist",
        "icon": "$(link-external)"
      }
    ],
    "configuration": {
      "title": "Zettelgeist",
      "properties": {
        "zettelgeist.theme": {
          "type": "string",
          "default": "auto",
          "enum": ["auto", "light", "dark"],
          "description": "Viewer theme. `auto` follows the VSCode color theme."
        },
        "zettelgeist.defaultView": {
          "type": "string",
          "default": "board",
          "enum": ["board", "graph", "docs"],
          "enumDescriptions": [
            "Open the kanban board first",
            "Open the dependency graph first",
            "Open the docs first"
          ],
          "description": "Which view the board panel lands on when first opened."
        },
        "zettelgeist.autoOpenBoard": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open the board when a workspace containing .zettelgeist.yaml is loaded."
        },
        "zettelgeist.serverPort": {
          "type": "number",
          "default": 7681,
          "minimum": 1024,
          "maximum": 65535,
          "description": "Port used by 'Zettelgeist: Open in Browser' when spawning `zettelgeist serve`. Change if 7681 conflicts with another local service."
        },
        "zettelgeist.serverHost": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Host the 'Open in Browser' server binds to. Defaults to localhost-only for safety; set to 0.0.0.0 to share on the LAN."
        }
      }
    }
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@zettelgeist/core": "workspace:*",
    "@zettelgeist/fs-adapters": "workspace:*",
    "@zettelgeist/git-hook": "workspace:*",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "vitest": "^2.1.0"
  }
}
