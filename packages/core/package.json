{
  "name": "@zettelgeist/core",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "author": "Mo <motechnix@gmail.com>",
  "description": "Format core for Zettelgeist: parse, derive, validate, regenerate INDEX.md.",
  "keywords": ["zettelgeist", "spec-driven-development", "markdown", "project-management"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/morrieinmaas/zettelgeist.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/morrieinmaas/zettelgeist/issues",
  "homepage": "https://github.com/morrieinmaas/zettelgeist#readme",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "js-yaml": "^3.14.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9"
  }
}
